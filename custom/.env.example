# ─── Database ────────────────────────────────────────────────────────────────
# DB_TYPE=sqlite         ← default, gunakan SQLite (file lokal)
# DB_TYPE=postgresql     ← gunakan PostgreSQL
#
# SQLite — path file database (default: ./data/app.db, ':memory:' untuk testing)
# DB_PATH=./data/app.db
#
# PostgreSQL — hanya digunakan saat DB_TYPE=postgresql
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=n8n_custom
# PG_USER=postgres
# PG_PASSWORD=
# PG_SSL=false

# ─── n8n Connection ──────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_ADMIN_EMAIL=your-n8n-admin@email.com
N8N_ADMIN_PASSWORD=your-n8n-password

# n8n Public API Key — n8n UI > Settings > API > Create API Key
N8N_API_KEY=your-n8n-api-key-here

# Session secret — ganti dengan string acak panjang di production
SESSION_SECRET=ganti-dengan-random-string-panjang

# Port custom app ini (default: 3000)
# PORT=3000

# ─── SSO dikonfigurasi via halaman Settings (/app/settings) ──────────────────
# Tidak perlu menambahkan credentials SSO di sini.
# Login ke app → Settings → SSO / Login → isi form → Simpan.
#
# Untuk Azure Entra ID, buat App Registration di Azure Portal:
# 1. Azure Portal > Entra ID > App registrations > New registration
# 2. Redirect URI: Web → http://localhost:3000/auth/sso/callback
# 3. API permissions: openid, email, profile
# 4. Certificates & Secrets > New client secret
